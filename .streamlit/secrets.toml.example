# LOCAL secrets template (optional — .env also works locally).
# On Streamlit Community Cloud you DON'T upload this file; instead you paste
# the same line into:  App → Settings → Secrets.
#
# Copy this file to ".streamlit/secrets.toml" for local use, or paste the line
# below into the Streamlit Cloud Secrets box. Never commit the real key.

ANTHROPIC_API_KEY = "sk-ant-your-key-here"
